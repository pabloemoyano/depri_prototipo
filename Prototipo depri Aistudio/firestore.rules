rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // 2. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Collection Matches
    match /stock/{itemId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // Allow update for healing/fixing scripts
    }

    match /customers/{customerId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /providers/{providerId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /events/{eventId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /purchases/{purchaseId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /tables/{tableId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /inventory_movements/{moveId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /presentations/{presId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /caja_active/{docId} {
      allow read, write: if isSignedIn();
    }

    match /caja_history/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /caja_tarifas/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /audits/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /budgets/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /ledger_manual/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /pending_classifications/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
